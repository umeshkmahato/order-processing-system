{
  "info": {
    "_postman_id": "f6f74371-06f5-4ad7-9220-ee63708e92f1",
    "name": "E-commerce Order Processing System",
    "description": "Postman collection for Spring Boot Order Processing APIs with standardized ApiResponse wrappers and OpenAPI endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"John Doe\",\n  \"customerEmail\": \"john@example.com\",\n  \"items\": [\n    {\n      \"productId\": \"P100\",\n      \"productName\": \"Laptop\",\n      \"quantity\": 1,\n      \"unitPrice\": 50000\n    },\n    {\n      \"productId\": \"P200\",\n      \"productName\": \"Mouse\",\n      \"quantity\": 2,\n      \"unitPrice\": 500\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response indicates success', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.message).to.eql('Order created successfully');",
              "    pm.expect(json.data.status).to.eql('PENDING');",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "    pm.environment.set('orderId', json.data.id.toString());",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Order By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Wrapped order response is returned', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.message).to.eql('Order retrieved successfully');",
              "    pm.expect(json.data.id).to.exist;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Orders",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Wrapped list response is returned', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.message).to.eql('Orders retrieved successfully');",
              "    pm.expect(Array.isArray(json.data)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Orders By Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders?status={{status}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ],
          "query": [
            {
              "key": "status",
              "value": "{{status}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Filtered wrapped list response is returned', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.message).to.eql('Orders retrieved successfully');",
              "    pm.expect(Array.isArray(json.data)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"SHIPPED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}",
            "status"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Wrapped status update response is returned', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.message).to.eql('Order status updated successfully');",
              "    pm.expect(json.data.status).to.eql('SHIPPED');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Cancel Order",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}",
            "cancel"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Wrapped cancellation response is returned', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "    pm.expect(json.message).to.eql('Order cancelled successfully');",
              "    pm.expect(json.data.status).to.eql('CANCELLED');",
              "});"
            ]
          }
        }
      ]
    },
